---
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Projects from "../components/Projects.astro";
import Experience from "../components/Experience.astro";
import Education from "../components/Education.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config";
import "../styles/global.css";
import News from "../components/News.astro";
import MouseSpotlight from "../components/mouseSpotlight.astro";

const profilePageJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "@id": "https://aleg001.com/#profile-page",
  url: "https://aleg001.com/",
  name: "Ale Gómez | Alejandro José Gómez Hernández",
  mainEntity: {
    "@type": "Person",
    "@id": "https://aleg001.com/#alejandro-jose-gomez-hernandez",
    name: "Alejandro José Gómez Hernández",
    alternateName: ["Ale Gómez", "Ale Gomez", "aleg001", "aleg_001"],
    url: "https://aleg001.com/",
    image: [
      "https://aleg001.com/img/ALEJANDROGOMEZ.jpg",
      "https://aleg001.com/img/AlejandroJoseGomezHernandez.jpeg",
      "https://aleg001.com/img/Alejandro_Gomez.jpeg",
      "https://aleg001.com/img/AleGomez.JPG",
    ],
    jobTitle: ["Computer Science Engineer", "Full Stack Developer", "Musician"],
    description:
      "Alejandro José Gómez Hernández, also known as Ale Gómez, is a Computer Science Engineer, Full Stack Developer, and musician from Guatemala.",
    knowsAbout: [
      "Computer Science",
      "Artificial Intelligence",
      "Full Stack Development",
      "Music",
      "Piano",
      "Public Technology",
    ],
    nationality: {
      "@type": "Country",
      name: "Guatemala",
    },
    alumniOf: [
      {
        "@type": "CollegeOrUniversity",
        name: "Universidad del Valle de Guatemala",
      },
      {
        "@type": "EducationalOrganization",
        name: "Civic Tech Institute Alumni 2026",
        description:
          "Selected as the first Central American scholar for the Civic Tech Institute 2026, a 10-week program by Equitech Futures for emerging leaders in government, nonprofit, and social enterprise sectors focused on civic challenges, planetary health, data, AI, and advocacy for impact at scale.",
      },
    ],
    sameAs: [
      "https://github.com/aleg001",
      "https://www.linkedin.com/in/aleg001/",
      "https://open.spotify.com/artist/15VE9VbmAmb0R7htytJtt8",
      "https://www.instagram.com/aleg_001/",
    ],
  },
};
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title> {siteConfig.fullName} </title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={siteConfig.description} />
    <meta name="keywords" content={siteConfig.keywords.join(", ")} />
    <meta name="author" content={siteConfig.fullName} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={`${siteConfig.siteUrl}${Astro.url.pathname}`} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_GT" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={`${siteConfig.name} · ${siteConfig.title}`} />
    <meta property="og:description" content={siteConfig.description} />
    <meta property="og:url" content={`${siteConfig.siteUrl}${Astro.url.pathname}`} />

    <meta property="og:image:secure_url" content={`${siteConfig.siteUrl}${siteConfig.ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Ale Gómez, ingeniero en ciencia de la computación y músico en Guatemala" />


    <meta
      property="og:image"
      content={`${siteConfig.siteUrl}${siteConfig.ogImage}`}
    />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={`${siteConfig.name} · ${siteConfig.title}`} />
    <meta property="twitter:description" content={siteConfig.description} />
    <meta
      property="twitter:image"
      content={`${siteConfig.siteUrl}${siteConfig.ogImage}`}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(profilePageJsonLd)}
    >
    </script>
  </head>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BR2QEW8ZJ8"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-BR2QEW8ZJ8');
    </script>

  <body>
      <MouseSpotlight />
    <Header />
    <main>
      <Hero />
      <About />
      <Projects />
      <Experience />
      <News />
      <Education />
    </main>
    <Footer />
  </body>
</html>
